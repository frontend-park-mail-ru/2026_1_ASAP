{
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": ["jsdoc", "closure"]
    },
    "source": {
        "include": ["src"],
        "includePattern": "\\.js$",
        "excludePattern": "(node_modules|docs|\\.precompiled\\.js)"
    },
    "plugins": [],
    "opts": {
        "encoding": "utf8",
        "readme": "README.md",
        "destination": "./docs",
        "recurse": true,
        "template": "node_modules/docdash"
    },
    "templates": {
        "cleverLinks": true,
        "monospaceLinks": true
    }
}