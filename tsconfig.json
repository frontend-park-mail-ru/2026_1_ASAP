{
    "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "strict": false,
    
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "bundler",
    },
    "include": ["src/**/*.ts", "src/**/*.js", "src/types/**/*.d.ts"],
    "exclude": ["node_modules"]
}