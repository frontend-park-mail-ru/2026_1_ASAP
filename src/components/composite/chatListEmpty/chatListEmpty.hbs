<div class="chat-list-empty">
    <div class="ob-logo">
        <div class="ob-logo__ring ob-logo__ring--1"></div>
        <div class="ob-logo__ring ob-logo__ring--2"></div>
        <div class="ob-logo__ring ob-logo__ring--3"></div>
        <div class="ob-logo__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12h3l2-6 3 12 3-9 2 4h3"/>
            </svg>
        </div>
    </div>
    <div class="ob-wave">
        <span class="ob-wave__bar" style="--ob-h:0.3"></span>
        <span class="ob-wave__bar" style="--ob-h:0.5"></span>
        <span class="ob-wave__bar" style="--ob-h:0.8"></span>
        <span class="ob-wave__bar" style="--ob-h:1.0"></span>
        <span class="ob-wave__bar" style="--ob-h:0.7"></span>
        <span class="ob-wave__bar" style="--ob-h:0.9"></span>
        <span class="ob-wave__bar" style="--ob-h:0.5"></span>
        <span class="ob-wave__bar" style="--ob-h:0.6"></span>
        <span class="ob-wave__bar" style="--ob-h:1.0"></span>
        <span class="ob-wave__bar" style="--ob-h:0.8"></span>
        <span class="ob-wave__bar" style="--ob-h:0.4"></span>
        <span class="ob-wave__bar" style="--ob-h:0.6"></span>
        <span class="ob-wave__bar" style="--ob-h:0.9"></span>
        <span class="ob-wave__bar" style="--ob-h:0.7"></span>
        <span class="ob-wave__bar" style="--ob-h:0.5"></span>
        <span class="ob-wave__bar" style="--ob-h:0.4"></span>
        <span class="ob-wave__bar" style="--ob-h:0.7"></span>
        <span class="ob-wave__bar" style="--ob-h:0.8"></span>
        <span class="ob-wave__bar" style="--ob-h:0.5"></span>
        <span class="ob-wave__bar" style="--ob-h:0.3"></span>
    </div>
    <p class="chat-list-empty__hint">
        <span>{{#if text}}{{text}}{{else}}Начните общение — напишите первыми!{{/if}}</span>
        {{#if iconAfter}}<img class="chat-list-empty__hint-icon" src="{{iconAfter}}" alt="" aria-hidden="true">{{/if}}
    </p>
</div>
