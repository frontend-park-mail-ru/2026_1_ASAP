<div class="create-channel-window">
    <div class="create-channel-window__header" data-component="header-slot"></div>

    <div class="create-channel-window__body">
        <div class="create-channel-window__avatar-slot" data-component="avatar-slot"></div>

        <div class="create-channel-window__name-slot" data-component="name-slot"></div>

        <label class="create-channel-window__description-row">
            <span class="create-channel-window__description-label">Информация о канале:</span>
            <textarea
                class="create-channel-window__description-input"
                data-component="description-input"
                placeholder="Расскажите о вашем канале"
                rows="1"
            ></textarea>
        </label>

        <div class="create-channel-window__submit-slot" data-component="submit-slot"></div>
    </div>
</div>
