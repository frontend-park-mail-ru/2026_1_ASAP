<div class="support-overlay">
    <div class="support-overlay__scroll">
        <div class="support-overlay__header">
            <h1 class="support-overlay__title">Техподдержка Pulse</h1>
            <div class="support-overlay__header-actions"></div>
        </div>

        <div class="support-overlay__nav support-overlay__section">
            <p class="support-overlay__section-title">Раздел</p>
            <div class="support-overlay__nav-buttons"></div>
        </div>

        <div class="support-overlay__section">
            <p class="support-overlay__section-name">Как Вас зовут</p>
            <div class="support-overlay__name-input"></div>
        </div>

        <div class="support-overlay__section">
            <p class="support-overlay__section-title">Email</p>
            <div class="support-overlay__email-input"></div>
        </div>

        <div class="support-overlay__section">
            <p class="support-overlay__section-title">Тип обращения</p>
            <div class="support-overlay__issue-type-buttons" role="group" aria-label="Тип обращения"></div>
        </div>

        <div class="support-overlay__section support-overlay__section--grow">
            <p class="support-overlay__section-title">Опишите проблему</p>
            <div class="support-overlay__issue-input"></div>
        </div>

        <div class="support-overlay__section">
            <p class="support-overlay__section-title">Вложения</p>
            <div class="support-overlay__files-input"></div>
        </div>
    </div>

    <div class="support-overlay__footer">
        <div class="support-overlay__confirm"></div>
    </div>
</div>
