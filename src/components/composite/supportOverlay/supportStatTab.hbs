<div class="support-stat-tab">
    <div class="support-stat-tab__scroll">
        <div class="support-stat-tab__cards-row">
            <div class="support-stat-tab__stat-card">
                <p class="support-stat-tab__stat-label">ВСЕГО ОБРАЩЕНИЙ</p>
                <p class="support-stat-tab__stat-value" data-stat="total">—</p>
            </div>
        </div>

        <div class="support-stat-tab__section">
            <div class="support-stat-tab__section-header">
                <p class="support-stat-tab__section-title">Распределение по статусам</p>
                <p class="support-stat-tab__section-sub">за 30 дней</p>
            </div>
            <div class="support-stat-tab__status-bars" data-component="status-bars">
                <div class="support-stat-tab__placeholder">Статистика пока недоступна</div>
            </div>
        </div>
    </div>
</div>
