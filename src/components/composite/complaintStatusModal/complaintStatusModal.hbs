<div class="complaint-status-modal">
    <div class="complaint-status-modal__overlay" data-component="csm-overlay"></div>
    <div class="complaint-status-modal__container" data-component="csm-container">
        <h2 class="complaint-status-modal__title">Изменить статус</h2>
        <div class="complaint-status-modal__meta" data-component="csm-meta"></div>
        <div>
            <div class="complaint-status-modal__body-label">Обращение:</div>
            <div class="complaint-status-modal__body-text" data-component="csm-body"></div>
        </div>
        <div class="complaint-status-modal__current-status">
            Текущий статус: <span data-component="csm-current-status"></span>
        </div>
        <hr class="complaint-status-modal__divider" />
        <div class="complaint-status-modal__status-label">Выберите новый статус:</div>
        <div class="complaint-status-modal__status-buttons" data-component="csm-status-buttons"></div>
        <div class="complaint-status-modal__error" data-component="csm-error"></div>
    </div>
</div>
